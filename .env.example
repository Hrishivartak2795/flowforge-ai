# FlowForge AI — environment configuration TEMPLATE
# Copy to `.env` and fill in real values:  cp .env.example .env
# NEVER commit `.env` (it is git-ignored). This template lists variable
# NAMES only — no secrets. Each var notes the milestone that first uses it.

# ── Application (introduced in M0.3) ─────────────────
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── Database (introduced in M0.4 / M1) ───────────────
# App connection string (psycopg3 driver). Host `db` matches the
# Postgres service name in docker-compose; use `localhost` for host runs.
DATABASE_URL=postgresql+psycopg://flowforge:flowforge@db:5432/flowforge

# Credentials consumed by the Postgres container (docker-compose, M0.4)
POSTGRES_USER=flowforge
POSTGRES_PASSWORD=flowforge
POSTGRES_DB=flowforge

# ── Claude API (introduced in M5) ────────────────────
# Server-side ONLY. Never expose to the frontend. Leave blank until M5.
ANTHROPIC_API_KEY=

# ── Embeddings (introduced in M4) ────────────────────
EMBEDDING_MODEL=BAAI/bge-m3

# ── Ingestion (introduced in M2) ─────────────────────
# Local staging for extracted ZIPs and cloned repos. Ephemeral per container.
UPLOADS_DIR=/tmp/flowforge/uploads
# First-line defenses against zip-bomb / archive-DoS. The extractor rejects
# archives whose uncompressed size or entry count exceed these caps before
# writing anything to disk.
MAX_REPO_BYTES=209715200          # 200 MiB
MAX_FILES_PER_REPO=20000
# Wall-clock cap on git clone operations (seconds). GitPython sends SIGKILL
# after this. Default 120s is generous for public repos; reduce in tests.
CLONE_TIMEOUT_SECONDS=120
